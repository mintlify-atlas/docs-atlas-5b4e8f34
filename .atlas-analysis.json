  "keyFeatures": [
    "Reverse proxy management with load balancing (8 policies), health checks, and enable/disable toggle",
    "L4 TCP/UDP stream proxying with TLS SNI matching and proxy protocol support",
    "Automatic HTTPS via Caddy ACME (Let's Encrypt / ZeroSSL) with DNS-01 challenge for 12+ providers",
    "Mutual TLS (mTLS) with built-in CA for issuing, tracking, and revoking client certificates",
    "Web Application Firewall powered by Coraza with OWASP Core Rule Set (SQLi, XSS, LFI, RCE)",
    "Geo blocking by country, continent, ASN, CIDR range, or exact IP per proxy host",
    "Built-in forward auth portal — protect apps without an external IdP",
    "Traffic analytics via ClickHouse with live charts, country map, and WAF event log",
    "Full REST API at /api/v1/ with Bearer token auth and OpenAPI 3.1.0 docs",
    "Instance sync for master/slave multi-instance deployments",
    "OAuth2/OIDC SSO support (Authentik, Keycloak, Auth0, and more)",
    "Complete audit trail with user attribution for all configuration changes"
  ],
  "publicApiSurface": [
    "GET/POST /api/v1/proxy-hosts",
    "GET/PUT/DELETE /api/v1/proxy-hosts/{id}",
    "GET/POST /api/v1/l4-proxy-hosts",
